# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_pass
MYSQL_DATABASE=mymoneydb

# Database Connection URL
DATABASE_URL=mysql://root:your_pass@db:3306/mymoneydb

# JWT Configuration
JWT_SECRET=your_secret_key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_COOKIE_NAME=refresh_token

# Environment
NODE_ENV=development

# Ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=financial-advisor

# CORS — через запятую, если несколько
CORS_ORIGINS=http://localhost:3001,https://mymoney.cloudpub.ru/

# NEXT URLS
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001 # if run dev: 3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api # if run dev: 3000
NEXT_PUBLIC_COOKIE_DOMAIN=localhost